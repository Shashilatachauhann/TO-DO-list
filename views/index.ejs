<!DOCTYPE html>
<html>

<head>
    <title>My To-Do List</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: #f4f7f6;
            padding: 50px;
        }

        .container {
            max-width: 500px;
            margin: auto;
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        }

        h1 {
            text-align: center;
            color: #333;
        }

        .task-form {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        input,
        select,
        button {
            padding: 10px;
            border-radius: 5px;
            border: 1px solid #ddd;
        }

        ul {
            list-style: none;
            padding: 0;
        }

        li {
            background: #fff;
            border-bottom: 1px solid #eee;
            padding: 10px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .btn-del {
            background: #ff4d4d;
            color: white;
            border: none;
            cursor: pointer;
            padding: 5px 10px;
        }
    </style>
</head>

<body>
    <div class="container">
        <h1>My Tasks</h1>
        <form action="/add" method="POST" class="task-form">
            <input type="text" name="text" required placeholder="New task...">
            <select name="priority">
                <option value="High">High</option>
                <option value="Medium">Medium</option>
                <option value="Low">Low</option>
            </select>
            <button type="submit">Add</button>
        </form>

        <ul>
            <% tasks.forEach(task=> { %>
                <li>
                    <form action="/toggle/<%= task.id %>?_method=PUT" method="POST">
                        <button type="submit" style="cursor: pointer;">
                            <%= task.completed ? '✅' : '⬜' %>
                        </button>
                    </form>

                    <span style="text-decoration: <%= task.completed ? 'line-through' : 'none' %>; flex-grow: 1;">
                        <%= task.text %> <b>(<%= task.priority %>)</b>
                    </span>

                    <form action="/delete/<%= task.id %>?_method=DELETE" method="POST">
                        <button class="btn-del" type="submit">Delete</button>
                    </form>
                </li>
                <% }) %>
        </ul>
    </div>
</body>

</html>